# Copy to `.env` or `.env.local` and fill in values. Never commit real secrets.

NODE_ENV=development
JWT_SECRET=

# PostgreSQL (Supabase or local)
DATABASE_URL=

# Public site URL (optional; used for OG links and waiver emails)
NEXT_PUBLIC_SITE_URL=

# --- Webflow: check-in purchase history (optional but recommended for /admin/checkin) ---
# Token: Webflow Dashboard → your Workspace name (top left) → Workspace settings →
#   Integrations → API access → Generate API token. Enable scope: ecommerce:read (and sites:read if offered).
WEBFLOW_API_TOKEN=

# Site ID: Webflow Dashboard → open your site → Site settings → General (look for Site ID),
#   or call GET https://api.webflow.com/v2/sites with your token and copy the site id from the response.
WEBFLOW_SITE_ID=

# Optional JSON: map variant SKU string → party size (number of people per unit), e.g. {"party-pack-sku":3}
# CHECKIN_SKU_PARTY_SIZE={"airsoft-ftx-blockade-coyote-syndicate":1}

# Optional JSON: map SKU → short display label for the check-in UI
# CHECKIN_SKU_DISPLAY={"airsoft-ftx-blockade-coyote-syndicate":"Airsoft FTX — Coyote"}

# Optional JSON array for gate filter dropdown: product or variant id from Webflow + label
# CHECKIN_EVENTS_JSON=[{"id":"YOUR_PRODUCT_OR_VARIANT_ID","label":"Saturday game"}]

# Optional: cache duration for orders in ms (default 420000 = 7 minutes)
# CHECKIN_CACHE_TTL_MS=420000
